+    // Lazy preview loader for a single product_carousel section. Replaces
+    // the previous mount-time "fetch all carousels in parallel" effect
+    // that was the dominant cause of the 60s+ cold-load (bug #11).
+    //
+    // Behaviour:
+    //   - On mount: NOTHING is fetched. Each carousel shows a Load preview
+    //     button instead of empty preview space.
+    //   - On click of Load preview: fetches just that one section.
+    //   - On filter change: refetches only if the section's preview is
+    //     already live (previewLoaded === true). Editing filters on a
+    //     carousel that hasn't been previewed yet does not auto-fetch.
+    // This pattern is forward-compatible with the redesign in
+    // prompts/homepage-editor-redesign.md, where the popup open will
+    // simply call loadPreview(sectionIndex) instead of the button.
+    const loadPreview = async (sectionIndex: number) => {
+        const section = sectionStates.find(s => s.index === sectionIndex);
+        if (!section || section.type !== "product_carousel") return;
+        if (section.previewLoading) return;
+
+        setSectionStates(prev => prev.map(s =>
+            s.index === sectionIndex ? { ...s, previewLoading: true } : s
+        ));
+
+        const filter: Record<string, unknown> = {};
+        if (section.category) filter.category = section.category;
+        if (section.brand) filter.brand = section.brand;
+        if (section.modelLine) filter.name = section.modelLine;
+        if (section.traction) filter.traction = section.traction;
+        if (section.minPrice) filter.minPrice = parseFloat(section.minPrice);
+        if (section.maxPrice) filter.maxPrice = parseFloat(section.maxPrice);
+
+        const result = await getPreviewProducts(filter, section.sort, parseInt(section.limit) || 10);
+        const products = (!result.error && result.data) ? result.data : [];
+
+        setSectionStates(prev => prev.map(s =>
+            s.index === sectionIndex
+                ? { ...s, previewProducts: products, previewLoaded: true, previewLoading: false }
+                : s
+        ));
+    };
+
+    // Refetch-on-filter-change, but ONLY for sections whose preview is
